// binaryTargets 覆盖 x86_64 / arm64 两种架构，避免构建与运行环境不一致导致引擎二进制不匹配
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FuelType {
  P92
  P95
  P98
  DIESEL
  ELECTRIC
}

enum Role {
  ADMIN
  USER
}

model User {
  id                 String    @id @default(uuid())
  // 登录用账号名，取代原来"用邮箱登录"的方式；email 改为可选，仅用于找回密码邮件
  username           String    @unique
  email              String?   @unique
  passwordHash       String
  // ADMIN：系统初始化时自动创建的那个账号（迁移时把历史数据里最早注册的账号回填为 ADMIN）。
  // 单用户模式（SystemSetting.multiUserEnabled = false）下，ADMIN 能看到系统里所有账号的数据。
  role               Role      @default(USER)
  totpSecret         String?
  totpEnabled        Boolean   @default(false)
  failedLoginCount   Int       @default(0)
  lockedUntil        DateTime?
  resetToken         String?
  resetTokenExpires  DateTime?
  // 首次使用默认管理员账号登录后，强制要求修改密码，改密成功后置为 false
  mustChangePassword Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  vehicles      Vehicle[]
  loginAttempts LoginAttempt[]
}

// 全局系统设置，单例表（固定只有 id=1 这一行）。
// multiUserEnabled 默认 false：单用户模式下不开放注册，ADMIN 账号能读取所有用户的数据；
// 由 ADMIN 在设置页里主动开启后，才切换成正常的多用户隔离（各账号只能看到自己的数据）。
model SystemSetting {
  id               Int     @id @default(1)
  multiUserEnabled Boolean @default(false)
}

// 登录尝试记录，用于暴力破解检测与审计
model LoginAttempt {
  id        String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  // 登录时实际输入的账号名（现在是 username，历史数据里可能是邮箱），仅用于审计展示
  identifier String
  ip         String
  success    Boolean
  createdAt  DateTime @default(now())

  @@index([ip, createdAt])
  @@index([identifier, createdAt])
}

// IP 黑名单，命中后直接拒绝请求
model IpBlacklist {
  id        String    @id @default(uuid())
  ip        String    @unique
  reason    String?
  createdAt DateTime  @default(now())
  expiresAt DateTime?
}

// 设备（车辆）
model Vehicle {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  brand           String?
  model           String?
  plateNo         String?
  coverImageUrl   String?
  // 封面裁剪范围，例如 { x, y, width, height, zoom }，供多端按同一范围渲染封面
  coverCrop       Json?
  defaultFuelType FuelType @default(P92)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  maintenanceRecords MaintenanceRecord[]
  fuelRecords        FuelRecord[]
  expenseRecords     ExpenseRecord[]

  @@index([userId])
}

// 单次保养记录
model MaintenanceRecord {
  id             String   @id @default(uuid())
  vehicleId      String
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date           DateTime
  mileage        Int?
  remark         String?
  // 保养项目合计之外的整单优惠金额，totalPrice = 各项目合计 - discountAmount（不低于 0）
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)
  totalPrice     Decimal  @default(0) @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items MaintenanceItem[]

  @@index([vehicleId, date])
}

// 保养项目明细：项目、品牌、个数、价格
model MaintenanceItem {
  id                   String            @id @default(uuid())
  maintenanceRecordId  String
  maintenanceRecord    MaintenanceRecord @relation(fields: [maintenanceRecordId], references: [id], onDelete: Cascade)
  project              String
  brand                String?
  quantity             Int     @default(1)
  price                Decimal @db.Decimal(10, 2)

  @@index([maintenanceRecordId])
}

// 油耗记录
model FuelRecord {
  id           String   @id @default(uuid())
  vehicleId    String
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date         DateTime
  mileage      Int
  volume       Decimal  @db.Decimal(6, 2)
  unitPrice    Decimal  @db.Decimal(6, 2)
  fuelType     FuelType
  // 是否跳枪（加油枪自动跳停，代表加满）
  isFullTank   Boolean  @default(true)
  // 上次加油是否有记录（影响油耗计算准确性）
  lastRecorded Boolean  @default(true)
  remark       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([vehicleId, date])
}

// 其他消费记录：在这辆车上花费的、不属于保养/加油的杂项支出，如停车费、行车记录仪、脚垫等
model ExpenseRecord {
  id        String   @id @default(uuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date      DateTime
  // 消费项目名称，如"停车费"“行车记录仪”
  item      String
  amount    Decimal  @db.Decimal(10, 2)
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId, date])
}

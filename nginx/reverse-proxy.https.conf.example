# HTTPS 配置模板。
# 使用方法：
#   1. 将证书文件放入 ./certs 目录，命名为 fullchain.pem 与 privkey.pem
#      （或自行修改下方 ssl_certificate / ssl_certificate_key 路径）
#   2. 将本文件复制为 nginx/reverse-proxy.conf（覆盖默认的 HTTP-only 配置）
#   3. 执行 docker compose restart nginx
#
# 注意：下面 HTTP -> HTTPS 跳转写死了端口 8083（对应 docker-compose.yml 里
# nginx 默认映射的 HTTPS 宿主机端口）。如果你在 .env 里把 HTTPS_PORT 改成了
# 别的值，或者用的是标准 443 端口，记得把下面这一行的 8083 也同步改掉，
# 否则跳转会带着错误的端口号，浏览器打不开。

client_max_body_size 20m;

server {
    listen 80;
    server_name _;
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }
    location / {
        return 301 https://$host:8083$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name _;

    ssl_certificate     /etc/nginx/certs/fullchain.pem;
    ssl_certificate_key /etc/nginx/certs/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;

    location /api/ {
        proxy_pass http://backend:3000/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /uploads/ {
        alias /app/uploads/;
        expires 7d;
        add_header Cache-Control "public";
    }

    location / {
        proxy_pass http://frontend:80/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# ===== 通用 =====
DOMAIN=localhost
NODE_ENV=production

# ===== 数据库 =====
POSTGRES_USER=vma_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=vehicle_maintenance
DATABASE_URL=postgresql://vma_user:change_me_strong_password@postgres:5432/vehicle_maintenance?schema=public

# ===== 鉴权 =====
JWT_ACCESS_SECRET=change_me_access_secret_please_use_random_64_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_please_use_random_64_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ===== 暴力破解防护 =====
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=100

# ===== 邮件 (用于忘记密码) =====
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@example.com
SMTP_PASS=change_me
MAIL_FROM="车辆保养管理 <no-reply@example.com>"

# ===== 前端 =====
FRONTEND_ORIGIN=https://localhost
VITE_API_BASE_URL=/api

# ===== 默认管理员账号 =====
# 仅在数据库中还没有任何账号时，首次启动会自动创建该账号，登录后会强制要求修改密码。
# 建议部署前就改成自己的值，而不是用默认值登录后再改。
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin123456

# ===== HTTPS =====
# 证书文件路径由 nginx/reverse-proxy.https.conf.example 中的
# ssl_certificate / ssl_certificate_key 固定指向 ./certs/fullchain.pem 与
# ./certs/privkey.pem，此处无需也不通过环境变量配置，见 README「启用 HTTPS」章节。
